{{!log "opponent" this}}
<section class="opponent-section">
  <header class="sheet-header {{#if (or hasImage unlocked)}}grid-image{{else}}grid-noimage{{/if}}">

    <div class="opponent-image">
      {{#if unlocked}}
        <img class="editable-image" src="{{actor.img}}" data-action="editImage" data-edit="img" data-uuid="{{actor.uuid}}" data-tooltip="{{localize 'TOOLTIPS.SelectImage'}}"/>
      {{else}}
        {{#if hasImage}}
          <img class="actor-image" src="{{actor.img}}" data-tooltip="{{actor.name}}"/>
          <a class="hover-icon" data-action="shareImage" data-tooltip="{{localize 'TOOLTIPS.ShowImage'}}" data-image="{{actor.img}}" data-name="{{actor.name}}"><i class="fas fa-image fa-fw"></i></a>
        {{/if}}
      {{/if}}
    </div>

    <div class="character">
      <div class="name">
        {{#if unlocked}}
          {{formInput fields.name value=actor.name name="name"}}
        {{else}}
          <div data-action="searchName" data-name="{{actor.name}}" data-tooltip="{{localize 'TOOLTIPS.SearchName'}}">{{actor.name}}</div>
        {{/if}}
      </div>
    </div>

    <div class="short-description">
      {{#if unlocked}}
        {{formInput systemFields.shortDescription value=system.shortDescription name="system.shortDescription" elementType="input" placeholder=(localize "CTHACK.ShortDescription")}}
      {{else}}
        {{{system.shortDescription}}}
      {{/if}}
    </div>

    <div class="data-group hitdice">
      <label for="system.hitDice" class="resource-label resource-name" data-tooltip="{{localize 'CTHACK.HitDice'}}">{{localize "CTHACK.HitDiceShort"}}</label>
      {{#if unlocked}}
        {{formInput systemFields.hitDice value=system.hitDice name="system.hitDice" choices=opponentHitDice}}
      {{else}}
        <div>{{system.hitDice}}</div>
      {{/if}}
    </div>

    <div class="data-group hp">
      <label for="system.hp.value" class="resource-label" data-tooltip="{{localize 'CTHACK.HitPoints'}}">{{localize "CTHACK.HitPointsShort"}}</label>
      <div class="hp-input">
        {{formInput systemFields.hp.fields.value value=system.hp.value name="system.hp.value"}}
        /
        {{#if unlocked}}
          {{formInput systemFields.hp.fields.max value=system.hp.max name="system.hp.max"}}
        {{else}}
          <div class="hp-max">{{system.hp.max}}</div>
        {{/if}}
      </div>
    </div>

    <div class="data-group armor">
      <label class="resource-label" data-tooltip="{{localize 'CTHACK.OpponentArmor'}}">{{localize "CTHACK.OpponentArmorShort"}}</label>
      {{#if unlocked}}
        {{formInput systemFields.armor value=system.armor name="system.armor"}}
      {{else}}
        <div>{{system.armor}}</div>
      {{/if}}
    </div>

    <div class="data-group malus">
      <label class="resource-label" data-tooltip="{{localize 'CTHACK.OpponentTouchMalus'}}">{{localize "CTHACK.OpponentTouchMalusShort"}}</label>
      {{#if unlocked}}
        {{formInput systemFields.malus value=system.malus name="system.malus"}}
      {{else}}
        <div>{{system.malus}}</div>
      {{/if}}
    </div>
  </header>

  {{! Sheet Body }}
  <section class="sheet-body {{#if hasImage}}grid-image{{else}}grid-noimage{{/if}}">

    {{#if unlocked}}
      <div class="description-editable">
        <div class="title">{{localize "CTHACK.Description"}}</div>
        {{formInput systemFields.description enriched=enrichedDescription value=system.description name="system.description" toggled=true}}
      </div>
    {{else}}
      <div class="description">
        {{{enrichedDescription}}}
      </div>
    {{/if}}

    <div class="attacks">
      {{#if unlocked}}
        <div class="title">{{localize "CTHACK.OpponentAttacks"}}
         <a class="item-control" data-action="createItem" data-tooltip="{{localize 'CTHACK.AddAttack'}}" data-type="attack"><i class="fas fa-plus"></i></a>
        </div>
      {{else}}
        {{#if (gt attacks.length 0)}}<div class="title">{{localize "CTHACK.OpponentAttacks"}}</div>{{/if}}
      {{/if}}
      <div class="grid-attacks">
        {{#each attacks as |attack id|}}
          <div class="item opponent-contextmenu" data-item-id="{{attack._id}}">
            <details>
              <summary class="item-line">
                <div class="item-name {{#if attack.system.hasDescription}}has-description{{/if}}">{{#if attack.hasImage}}<img src="{{attack.img}}"/>{{/if}}{{attack.name}}</div>
                <div class="item-details">{{#if attack.system.hasDamageDice}}<i class="fas fa-dice-d20 attack rollable" data-action="rollAttack">&nbsp;&nbsp;</i> {{/if}}{{{attack.system.details}}}</div>
              </summary>
              <div class="item-description">{{{attack.enrichedDescription}}}</div>
            </details>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="abilities">
      {{#if unlocked}}
        <div class="title">{{localize "CTHACK.OpponentAbilities"}}
          <a class="item-control" data-action="createItem" data-tooltip="{{localize 'CTHACK.AddOpponentAbility'}}" data-type="opponentAbility"><i class="fas fa-plus"></i></a>
        </div>
      {{else}}
        {{#if (gt opponentAbilities.length 0)}}<div class="title">{{localize "CTHACK.OpponentAbilities"}}</div>{{/if}}
      {{/if}}
      <div class="grid-opponent-abilities">
        {{#each opponentAbilities as |ability id|}}
          <div class="item opponent-contextmenu" data-item-id="{{ability._id}}">
            <details>
              <summary class="item-line">
                <div class="item-name {{#if ability.system.hasDescription}}has-description{{/if}}">{{#if ability.hasImage}}<img src="{{ability.img}}"/>{{/if}}{{ability.name}}</div>
                <div class="item-use">
                  {{#if ability.system.hasUse}}
                    {{localize 'CTHACK.AbilityUseValue'}} ({{abilityPeriodToString ability.system.uses.per}}) : {{ability.system.uses.value}}/{{ability.system.uses.max}}
                  {{/if}}
                </div>
              </summary>
              <div class="item-description">{{{ability.enrichedDescription}}}</div>
            </details>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="magics">
      {{#if unlocked}}
        <div class="title">{{localize "CTHACK.OpponentMagics"}}
          <a class="item-control" data-action="createItem" data-tooltip="{{localize 'CTHACK.AddMagic'}}" data-type="magic"><i class="fas fa-plus"></i></a>
        </div>
      {{else}}
        {{#if (gt magics.length 0)}}<div class="title">{{localize "CTHACK.OpponentMagics"}}</div>{{/if}}
      {{/if}}
      <div class="grid-magics">
        {{#each magics as |magic id|}}
          <div class="item opponent-contextmenu" data-item-id="{{magic._id}}">
            <details>
              <summary class="item-line">
                <div class="item-name {{#if magic.system.hasDescription}}has-description{{/if}}">{{#if magic.hasImage}}<img src="{{magic.img}}"/>{{/if}}{{{magic.name}}}</div>
                <div class="item-subtype">{{magic.system.subtypeLabel}}</div>
                <div class="item-dice">{{#if magic.system.isDice}}<i class="fas fa-dice-d20 sanity rollable" data-action="rollSanity">&nbsp;&nbsp;</i>{{magic.system.dice}}{{/if}}</div>
                <div class="item-incantation">{{magic.system.incantation}}</div>
              </summary>
              <div class="item-description">{{{magic.enrichedDescription}}}</div>
            </details>
          </div>
        {{/each}}
      </div>
    </div>
  </section>
</section>
