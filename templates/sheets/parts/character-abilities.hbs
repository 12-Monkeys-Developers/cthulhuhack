<section class="tab abilities {{tabs.abilities.cssClass}} abilities-magic" data-group="primary" data-tab="abilities">

    {{!-- Abilities--}}
    <div class="abilities">
        {{#if unlocked}}
            <div class="title">{{localize "CTHACK.Abilities"}}
                <a class="item-control" data-action="createItem" data-tooltip="{{localize "CTHACK.AddAbility"}}" data-type="ability"><i class="fas fa-plus"></i></a>
            </div>
        {{else}}
            {{#if (gt abilities.length 0)}}<div class="title">{{localize "CTHACK.Abilities"}}</div>{{/if}}
        {{/if}}

        <div class="grid-abilities">
            {{#each abilities as |item id|}}
                <div class="item character-contextmenu" data-item-id="{{_id}}">
                  <details>
                    <summary class="item-line">
                      <div class="item-name {{#if system.hasDescription}}has-description{{/if}}">{{#if hasImage}}<img src="{{img}}"/>{{/if}}{{{name}}}</div>
                      <div class="item-use">
                        {{#if system.hasUse}}
                          {{localize 'CTHACK.AbilityUseValue'}} ({{abilityPeriodToString system.uses.per}}) : {{system.uses.value}}/{{system.uses.max}} &nbsp;&nbsp;&nbsp;
                        {{/if}}
                      </div>
                      <div class="item-use-last">
                        {{#if system.hasLastUse}}
                           {{localize 'CTHACK.AbilityUseLast'}} : {{system.uses.last}}
                        {{/if}}
                      </div>
                    </summary>
                     <div class="item-description" {{#if system.advantageGiven}}data-tooltip="{{localize "CTHACK.AbilityAdvantageGiven"}} : {{{system.advantageText}}}"{{/if}}>{{{enrichedDescription}}}</div>
                  </details>
                </div>
            {{/each}}
        </div>
    </div>

    {{!-- Magic --}}
    <div class="magics">
         {{#if unlocked}}
            <div class="title">{{localize "CTHACK.Ui.Magic"}}
                <a class="item-control" data-action="createItem" data-tooltip="{{localize "CTHACK.AddMagic"}}" data-type="magic"><i class="fas fa-plus"></i></a>
            </div>
         {{else}}
            {{#if (gt magics.length 0)}}<div class="title">{{localize "CTHACK.Ui.Magic"}}</div>{{/if}}
         {{/if}}

        <div class="grid-magics">
            {{#each magics as |item id|}}
                <div class="item character-contextmenu" data-item-id="{{_id}}">
                    <details>
                        <summary class="item-line">
                            <div class="item-name {{#if system.hasDescription}}has-description{{/if}}">{{#if system.hasImage}}<img src="{{img}}"/>{{/if}}{{{name}}}</div>
                            <div class="item-subtype">{{magicTypeToString system.subtype}}</div>
                            <div class="item-dice item" data-item-id="{{_id}}">
                                {{#if (isDiceRollable system.dice)}} <img class="dice-d20 sanity rollable" data-action="rollSanity" data-tooltip="{{localize 'CTHACK.Roll.sanity'}}" src="systems/cthack/ui/dice/d20.webp"> {{/if}}
                                <select class="item-dice-select" name="system.dice" data-type="String" {{{getStyleForDice system.dice}}} disabled>
                                    {{selectOptions @root.diceValues selected=system.dice blank="CTHACK.Empty" localize=true}}
                                </select>
                            </div>
                            <div class="item-incantation">{{system.incantation}}</div>
                        </summary>
                        <div class="item-description">{{{enrichedDescription}}}</div>
                    </details>
                </div>
            {{/each}}
        </div>
    </div>

</section>
