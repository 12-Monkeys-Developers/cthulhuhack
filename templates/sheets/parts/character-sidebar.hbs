{{!log 'sidebar' this}}
<div class="sidebar flexcol">
  <div class="image-container">
    {{#if unlocked}}
      <img class="editable-image" src="{{actor.img}}" data-action="editImage" data-edit="img" data-uuid="{{actor.uuid}}" data-tooltip="{{localize 'TOOLTIPS.SelectImage'}}"/>
    {{else}}
      <img class="actor-image" src="{{actor.img}}" data-tooltip="{{actor.name}}"/>
      <a class="hover-icon" data-action="shareImage" data-tooltip="{{localize 'TOOLTIPS.ShowImage'}}" data-image="{{actor.img}}" data-name="{{actor.name}}"><i class="fas fa-image fa-fw"></i></a>
    {{/if}}
  </div>

  {{#each savesContext as |save|}}
    <div class="sidebar-section" data-save="{{save.key}}" data-drag="true" data-drag-type="save" data-drag-target="{{save.key}}" data-drag-value="{{save.value}}">
      <label class="save-name rollable" data-action="rollSave" data-tooltip="{{localize (toDesc save.key)}}" data-tooltip-direction="UP" data-tooltip-class="tooltip-save">{{getSaveLabel save.key save}}</label>
      {{#if @root.unlocked}}
        {{formInput save.valueField value=save.value name=save.valueName}}
        {{formInput save.advantageField value=save.advantage name=save.advantageName}}
      {{else}}
        {{save.value}}
      {{/if}}
    </div>
  {{/each}}
  {{#if (isEnabled "FortuneAvailable")}}
    <div class="fortune character-sidebar-contextmenu">
      <label class="resource-label">{{localize "CTHACK.Fortune"}} : {{getFortuneValue}}</label>
    </div>
  {{/if}}
  {{#if (isEnabled "Adrenaline")}}
    <div class="adrenaline">
      <img class="adrenaline-img" data-action="toggleAdrenaline" data-adrenaline="1" src="{{getAdrenalineImage system.attributes.adrenaline1.value}}" />
      <img class="adrenaline-img" data-action="toggleAdrenaline" data-adrenaline="2" src="{{getAdrenalineImage system.attributes.adrenaline2.value}}" />
    </div>
  {{/if}}
  {{#if (gt conditions.length 0)}}
    <div class="conditions">
      <div class="conditions-title">{{localize "CTHACK.Conditions"}}</div>
      <div class="items-list">
        {{#each conditions as |condition id|}}
          {{!log 'condition' condition id}}
          <div class="item-line item character-contextmenu" data-item-id="{{condition._id}}">
            <div class="item-name-img {{#if condition.system.hasDescription}}has-description{{/if}}" data-tooltip="{{condition.enrichedDescription}}">{{#if condition.hasImage}}<img src="{{condition.img}}"/>{{/if}}{{condition.name}}</div>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}
</div>
