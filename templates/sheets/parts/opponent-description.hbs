<section class="tab description {{tabs.description.cssClass}}" data-group="primary" data-tab="description">
  <div class="sheet-body {{#if hasImage}}grid-image{{else}}grid-noimage{{/if}}">
    {{#if unlocked}}
      <div class="description-editable">
        {{formInput systemFields.description enriched=enrichedDescription value=system.description name="system.description" toggled=true}}
      </div>
    {{else}}
      <div class="description">
        {{{enrichedDescription}}}
      </div>
    {{/if}}
  </div>
</section>
