<section>
    {{log "weapon" this}}
        <div class="item-header">
            {{#if isEdit}}
                <img class="editable-image" data-action="editImage" data-uuid="{{item.uuid}}" src="{{item.img}}" data-edit="img" data-tooltip="{{localize 'TOOLTIPS.SelectImage'}}" />
                <input name="name" type="text" value="{{item.name}}" />
            {{else}}
                <img src="{{item.img}}" />
                <input name="name" type="text" value="{{item.name}}" disabled/>
            {{/if}}
            <div class="form-group">
                <label>{{localize "CTHACK.Material"}}</label>
                <div class="form-fields">
                    <select {{#if isPlay}}disabled{{/if}} class="select-dice-material" name="system.dice" data-type="String" {{{getStyleForDice system.dice}}}>
                        {{selectOptions diceValues selected=system.dice blank="CTHACK.None" localize=true}}
                    </select>
                </div>
            </div>
        </div>
        {{formGroup systemFields.range name=system.range value=systemSource.range localize=true blank="CTHACK.None" classes="select-range" disabled=isPlay}}
         <!--
        <div class="form-group">
            <label>{{localize "CTHACK.ItemRangeName"}}</label>
            <div class="form-fields">
                <select {{#if isPlay}}disabled{{/if}} class="select-range" name="system.range" data-type="String">
                    {{selectOptions rangeValues selected=system.range labelAttr="label" localize=true blank="CTHACK.None"}}
                </select>
            </div>
        </div>
        -->
        <!--
        {{formGroup systemFields.dice name=system.dice value=systemSource.dice localize=true blank="CTHACK.None" disabled=isPlay widget=diceWidget}}
        {{formGroup systemFields.range name=system.range value=systemSource.range localize=true blank="CTHACK.None" disabled=isPlay}}
            -->               
        {{#if isEdit}}
            <fieldset>
                <legend>{{localize "CTHACK.Description"}}</legend>
                {{formInput systemFields.description enriched=enrichedDescription value=system.description name="system.description" toggled=true disabled=false}}
            </fieldset>
        {{else}}
            {{#if system.hasDescription}}
                <fieldset>
                    <legend>{{localize "CTHACK.Description"}}</legend>
                    {{formInput systemFields.description enriched=enrichedDescription value=system.description name="system.description" toggled=true disabled=true}}
                </fieldset>
            {{/if}}
        {{/if}}
</section>
